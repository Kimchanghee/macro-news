# ── Required ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
SITE_URL=https://YOUR_DOMAIN
CRON_SECRET=GENERATE_A_LONG_RANDOM_STRING

# ── Vercel KV (Upstash Redis) ───────────────────────────────
# Create from Vercel Dashboard → Storage → KV. These auto-inject.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Pipeline tuning ─────────────────────────────────────────
MAX_ARTICLES_PER_RUN=5

# ── AI image generation (per-article hero + thumbnail) ──────
# Path 1: OpenAI Images API (gpt-image-2). Works in production on Vercel.
OPENAI_API_KEY=
# Path 2 (dev fallback): codex-image CLI via OAuth (https://github.com/wjb127/codex-image)
# Set ENABLE_CODEX_IMAGE=1 on a host where `codex` is installed and `codex login` is done.
ENABLE_CODEX_IMAGE=0
# Vercel Blob token (required to make generated images publicly accessible).
BLOB_READ_WRITE_TOKEN=

# ── MGID ────────────────────────────────────────────────────
# Loader script URL from MGID dashboard, e.g. //jsc.mgid.com/c/o/your-loader.js
NEXT_PUBLIC_MGID_LOADER=
NEXT_PUBLIC_MGID_WIDGET_ID=

# ── Adsterra (per-zone keys from Publisher dashboard) ───────
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=
NEXT_PUBLIC_ADSTERRA_NATIVE_KEY=
NEXT_PUBLIC_ADSTERRA_SOCIAL_KEY=
NEXT_PUBLIC_ADSTERRA_POPUNDER_KEY=
